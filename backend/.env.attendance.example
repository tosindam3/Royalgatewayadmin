# Attendance System Configuration

# Python Path (adjust for your system)
PYTHON_PATH=/usr/bin/python3
# Windows: PYTHON_PATH=C:\Python310\python.exe

# Redis Configuration (for caching and queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# Attendance Settings
ATTENDANCE_GEOFENCE_ENABLED=true
ATTENDANCE_PHOTO_REQUIRED=false
ATTENDANCE_MAX_PHOTO_SIZE=2048
